<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Profile — Wing Mate Staff</title>
  <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
  <link rel="stylesheet" href="/assets/css/wingmate.css">
</head>
<body>
<div class="wm-staff-layout">

  <!-- Sidebar -->
  <aside class="wm-sidebar">
    <div class="wm-sidebar-logo">
      <span class="logo-icon">✈</span>
      Wing Mate
    </div>
    <% if (user.staff_category === 'admin') { %>
      <a href="/staff/admin" class="wm-sidebar-link" id="sidebar-admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    <% } else if (user.staff_category === 'manager') { %>
      <a href="/staff/manager" class="wm-sidebar-link" id="sidebar-manager"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    <% } else { %>
      <a href="/staff/general" class="wm-sidebar-link" id="sidebar-general"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    <% } %>
    <div class="wm-sidebar-section-title" style="margin-top:12px;">Account</div>
    <a href="/staff/edit_profile" class="wm-sidebar-link active" id="sidebar-edit-profile"><i class="fas fa-user-edit"></i> Edit Profile</a>
    <div class="wm-sidebar-bottom">
      <a href="/staff/logout" class="wm-sidebar-link" id="sidebar-logout" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Log Out</a>
    </div>
  </aside>

  <!-- Content -->
  <main class="wm-staff-content">
    <div class="wm-staff-topbar">
      <div>
        <h1>Edit Profile</h1>
        <p style="color:var(--text-muted);font-size:0.88rem;margin-top:4px;">Update your personal information and password</p>
      </div>
      <div class="wm-user-pill">
        <div class="wm-user-avatar"><%= user.staffData.first_name.charAt(0).toUpperCase() %></div>
        <span class="wm-user-name"><%= user.staffData.first_name %></span>
        <span class="wm-badge wm-badge-primary" style="margin-left:4px;"><%= user.staff_category %></span>
      </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="wm-alert wm-alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="wm-alert wm-alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <div class="wm-grid-2" style="gap:28px;align-items:start;">
      <!-- General Info -->
      <div class="wm-card">
        <h3 style="font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
          <i class="fas fa-user" style="color:var(--primary-light);"></i> Personal Information
        </h3>
        <form action="/staff/edit_profile/<%= user.staffId %>" method="POST">
          <div class="wm-form-group">
            <label>First Name</label>
            <input class="wm-input" type="text" name="firstName" value="<%= firstName %>" required>
          </div>
          <div class="wm-form-group">
            <label>Last Name</label>
            <input class="wm-input" type="text" name="lastName" value="<%= lastName %>" required>
          </div>
          <div class="wm-form-group">
            <label>Email Address</label>
            <input class="wm-input" type="email" name="email" value="<%= email %>" required>
          </div>
          <div class="wm-form-group">
            <label>Contact Number</label>
            <input class="wm-input" type="tel" name="contactNo" value="<%= contactNo %>" required>
          </div>
          <div class="wm-form-group">
            <label>Country</label>
            <input class="wm-input" type="text" name="country" value="<%= country %>" required>
          </div>
          <button type="submit" class="wm-btn wm-btn-primary" id="save-info-btn">
            <i class="fas fa-save"></i> Save Changes
          </button>
        </form>
      </div>

      <!-- Password + Delete -->
      <div style="display:flex;flex-direction:column;gap:24px;">
        <div class="wm-card" id="changePassword">
          <h3 style="font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
            <i class="fas fa-lock" style="color:var(--warning);"></i> Change Password
          </h3>
          <% if (typeof pwd_error !== 'undefined' && pwd_error) { %>
            <div class="wm-alert wm-alert-error"><i class="fas fa-exclamation-circle"></i> <%= pwd_error %></div>
          <% } %>
          <% if (typeof pwd_success !== 'undefined' && pwd_success) { %>
            <div class="wm-alert wm-alert-success"><i class="fas fa-check-circle"></i> <%= pwd_success %></div>
          <% } %>
          <form action="/staff/change_password/<%= user.staffId %>" method="POST">
            <div class="wm-form-group">
              <label>Current Password</label>
              <input class="wm-input" type="password" name="currentPassword" placeholder="••••••••" required>
            </div>
            <div class="wm-form-group">
              <label>New Password</label>
              <input class="wm-input" type="password" name="newPassword" placeholder="Min 8 characters" required>
            </div>
            <div class="wm-form-group">
              <label>Confirm New Password</label>
              <input class="wm-input" type="password" name="confirmNewPassword" placeholder="Repeat new password" required>
            </div>
            <button type="submit" class="wm-btn wm-btn-outline" id="change-pwd-btn">
              <i class="fas fa-key"></i> Update Password
            </button>
          </form>
        </div>

        <div class="wm-card" id="delAccount" style="border-color:rgba(239,68,68,0.2);">
          <h3 style="font-size:1rem;margin-bottom:12px;display:flex;align-items:center;gap:10px;color:var(--danger);">
            <i class="fas fa-exclamation-triangle"></i> Danger Zone
          </h3>
          <% if (typeof del_acc_error !== 'undefined' && del_acc_error) { %>
            <div class="wm-alert wm-alert-error"><i class="fas fa-exclamation-circle"></i> <%= del_acc_error %></div>
          <% } %>
          <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:16px;">Permanently delete your staff account. This cannot be undone.</p>
          <form action="/staff/delete_my_account/<%= user.staffId %>" method="POST" onsubmit="return confirm('Are you sure? This will permanently delete your account.')">
            <div class="wm-form-group">
              <label>Confirm with Password</label>
              <input class="wm-input wm-input-error" type="password" name="del_password" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="wm-btn wm-btn-danger" id="delete-account-btn">
              <i class="fas fa-trash-alt"></i> Delete My Account
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
