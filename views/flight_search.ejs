<%- include('_header', {user}) %>

<!-- Hero Banner Section -->
<section class="wm-hero" style="min-height: 50vh; padding-top: 140px; padding-bottom: 60px;">
  <div class="wm-hero-bg"></div>
  <div class="wm-hero-grid"></div>
  <div class="wm-hero-content" style="max-width: 800px;">
    <div class="wm-hero-pill">
      <span class="wm-hero-pill-dot"></span>
      Search Flights
    </div>
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 16px;">Find Your Next Destination</h1>
    <p style="margin-bottom: 0;">
      Compare schedules, choose routes, and secure your seat dynamically.
    </p>
  </div>
</section>

<!-- Breadcrumb -->
<div style="background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0;">
  <div class="wm-container">
    <div style="display: flex; gap: 8px; font-size: 0.85rem; color: var(--text-secondary);">
      <a href="/" style="color: var(--primary-light); hover:text-decoration: underline;">Home</a>
      <span>/</span>
      <span style="color: var(--text-primary);">Search Flights</span>
    </div>
  </div>
</div>

<!-- Search Widget Section -->
<section class="wm-section-sm" id="search">
  <div class="wm-container">
    <form action="/customer/viewFlights" method="GET">
      <div class="wm-search-widget">
        <div class="wm-search-row">
          
          <!-- From Airport -->
          <div class="wm-form-group" style="margin-bottom:0;">
            <label>Origin Airport</label>
            <select name="from" class="wm-select select-bar" style="height:52px;">
              <option value="">--Select FROM Airport--</option>
              <% if(airports && airports.length != 0) { %>
                <% airports.forEach(function(airport){ %>
                  <option value="<%= airport.airport_code %>" <%= (typeof from !== 'undefined' && from === airport.airport_code) ? 'selected' : '' %>>
                    <%= airport.name %> (<%= airport.airport_code %>)
                  </option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <!-- To Airport -->
          <div class="wm-form-group" style="margin-bottom:0;">
            <label>Destination Airport</label>
            <select name="to" class="wm-select select-bar" style="height:52px;">
              <option value="">--Select TO Airport--</option>
              <% if(airports && airports.length != 0) { %>
                <% airports.forEach(function(airport){ %>
                  <option value="<%= airport.airport_code %>" <%= (typeof to !== 'undefined' && to === airport.airport_code) ? 'selected' : '' %>>
                    <%= airport.name %> (<%= airport.airport_code %>)
                  </option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <!-- Date -->
          <div class="wm-form-group" style="margin-bottom:0;">
            <label>Departure Date</label>
            <input type="text" id="booking_date_from" name="booking_date_from" 
                   class="wm-input datepicker-here" data-language="en" placeholder="Departure Date" 
                   value="<%= typeof booking_date_from !== 'undefined' ? booking_date_from : '' %>"
                   style="height:52px; background: var(--bg-elevated); border: 1.5px solid var(--border); color: var(--text-primary);">
          </div>

          <!-- Submit Button -->
          <button type="submit" class="wm-btn wm-btn-primary wm-search-submit">
            <i class="fas fa-search"></i> Search Flights
          </button>
        </div>

        <div style="margin-top: 20px; font-size: 0.82rem; color: var(--text-muted); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
          <span>Current UTC Time: <%= new Date().toUTCString().slice(0, -3) %></span>
          <div style="display: flex; gap: 16px;">
            <a href="/customer/viewFlights" style="color: var(--primary-light);">Reset Search</a>
          </div>
        </div>
      </div>
    </form>
  </div>
</section>

<!-- Results Section -->
<section style="padding: 0 0 96px;">
  <div class="wm-container">
    <% if(typeof allFlights !== 'undefined' && allFlights && allFlights.length != 0) { %>
      <div class="wm-section-header" style="margin-bottom: 32px; text-align: left;">
        <span class="wm-eyebrow" style="justify-content: flex-start; margin-left:0;">Search Results</span>
        <h2>Available Flights Found</h2>
      </div>

      <div class="wm-table-wrap">
        <table class="wm-table">
          <thead>
            <tr>
              <th>Flight</th>
              <th>Origin</th>
              <th>Takeoff (UTC)</th>
              <th>Destination</th>
              <th>Landing (UTC)</th>
              <th style="text-align: right;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% allFlights.forEach(function(flight){ %>
              <tr>
                <td>
                  <span class="wm-badge wm-badge-primary"><%= flight.route_id %></span>
                </td>
                <td>
                  <strong style="color: var(--text-primary);"><%= flight.origin %></strong>
                </td>
                <td>
                  <%= (flight.departure_date).toString().substring(0,15) %> <span style="color: var(--primary-light); margin-left: 6px;"><%= flight.departure_time_utc %></span>
                </td>
                <td>
                  <strong style="color: var(--text-primary);"><%= flight.destination %></strong>
                </td>
                <td>
                  <%= (flight.arrival_date).toString().substring(0,15) %> <span style="color: var(--accent); margin-left: 6px;"><%= flight.arrival_time_utc %></span>
                </td>
                <td style="text-align: right;">
                  <form action="/booking" method="POST" style="display: inline-block;">
                    <input type="hidden" name="schedule_id" value="<%= flight.schedule_id %>">
                    <button type="submit" class="wm-btn wm-btn-primary wm-btn-sm">
                      Book Seat
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div style="margin-top: 24px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 14px;">
        <a href="#search" style="color: var(--primary-light); font-size: 0.9rem;"><i class="fas fa-arrow-up"></i> Search another date</a>
        <a href="/customer/viewFlights" style="color: var(--accent); font-size: 0.9rem;">View All Upcoming Flights <i class="fas fa-arrow-right"></i></a>
      </div>

    <% } else { %>
      <!-- Alert when no specific search results are active -->
      <% if(typeof booking_date_from !== 'undefined' && booking_date_from) { %>
        <div class="wm-card" style="border-color: var(--danger); background: rgba(239, 68, 68, 0.04); padding: 32px; text-align: center;">
          <div style="width: 56px; height: 56px; background: rgba(239, 68, 68, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: var(--danger); margin: 0 auto 16px;">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
          <h3 style="font-size: 1.3rem; margin-bottom: 8px;">No Flights Available</h3>
          <p style="color: var(--text-secondary); max-width: 500px; margin: 0 auto 16px;">
            There are no flights scheduled from <%= from %> to <%= to %> on <%= booking_date_from %>.
          </p>
          <a href="#upcomingFlights" class="wm-btn wm-btn-outline wm-btn-sm">View Other Upcoming Flights</a>
        </div>
      <% } %>
    <% } %>

    <!-- Upcoming Flights Grid -->
    <% if(typeof upcomingFlights !== 'undefined' && upcomingFlights && upcomingFlights.length != 0) { %>
      <div class="wm-section" id="upcomingFlights" style="padding-top: 64px;">
        <div class="wm-section-header">
          <span class="wm-eyebrow">Aviation Schedules</span>
          <h2>All Upcoming Flights</h2>
          <p>Explore scheduled flights and book tickets directly below.</p>
        </div>

        <div class="wm-grid-3">
          <% upcomingFlights.forEach(function(flight){ %>
            <div class="wm-flight-card">
              <div class="wm-flight-card-thumb">
                <img src="<%= flight.destination_image %>" alt="<%= flight.destination %>" onerror="this.src='/assets/images/Logo/w1.png'">
                <div class="wm-flight-card-price">from $<%= flight.price %></div>
              </div>
              <div class="wm-flight-card-body">
                <div class="wm-flight-route">
                  <div class="wm-flight-city"><%= flight.origin %></div>
                  <div class="wm-flight-arrow"><i class="fas fa-plane"></i></div>
                  <div class="wm-flight-city"><%= flight.destination %></div>
                </div>

                <div class="wm-flight-meta">
                  <div class="wm-flight-meta-item">
                    <i class="fas fa-clock"></i> 
                    <span><%= flight.departure_time_utc %> - <%= flight.arrival_time_utc %> UTC</span>
                  </div>
                  <div class="wm-flight-meta-item">
                    <i class="fas fa-calendar-alt"></i> 
                    <span><%= (flight.departure_date).toString().substring(0,10) %></span>
                  </div>
                  <div class="wm-flight-meta-item">
                    <i class="fas fa-plane-departure"></i> 
                    <span>Wing Mate Express</span>
                  </div>
                </div>

                <form action="/booking" method="POST" style="margin-top: auto;">
                  <input type="hidden" name="schedule_id" value="<%= flight.schedule_id %>">
                  <button type="submit" class="wm-btn wm-btn-primary wm-btn-full">
                    Book Flight
                  </button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Customer Reviews slider -->
    <% if(typeof reviews !== 'undefined' && reviews && reviews.length != 0) { %>
      <section class="wm-section" style="padding-top: 32px;">
        <div class="wm-section-header">
          <span class="wm-eyebrow">Reviews</span>
          <h2>What Our Travelers Say</h2>
          <p>Read experiences from regular and business class frequent flyers.</p>
        </div>

        <div class="swiper-container client-slider--style">
          <div class="swiper-wrapper">
            <% reviews.forEach(function(review){ %>
              <div class="swiper-slide">
                <div class="wm-review-card">
                  <div class="wm-review-quote">“</div>
                  <p class="wm-review-text"><%= review.review %></p>
                  <div class="wm-review-author">
                    <div class="wm-review-avatar">
                      <%= review.first_name.charAt(0) %>
                    </div>
                    <div>
                      <div class="wm-review-name"><%= review.first_name %> <%= review.last_name %></div>
                      <div class="wm-review-type"><%= review.category %> Flyer</div>
                    </div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </section>
    <% } %>

  </div>
</section>

<%- include('_footer', {user}) %>