<%- include('_header', {user}) %>

<!-- Hero Banner Section -->
<section class="wm-hero" style="min-height: 50vh; padding-top: 140px; padding-bottom: 60px;">
  <div class="wm-hero-bg"></div>
  <div class="wm-hero-grid"></div>
  <div class="wm-hero-content" style="max-width: 800px;">
    <div class="wm-hero-pill">
      <span class="wm-hero-pill-dot"></span>
      About Wing Mate
    </div>
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 16px;">Redefining Modern Aviation</h1>
    <p style="margin-bottom: 0;">
      Learn about our vision, our standards, and why we are trusted by thousands of travelers worldwide.
    </p>
  </div>
</section>

<!-- Breadcrumb -->
<div style="background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0;">
  <div class="wm-container">
    <div style="display: flex; gap: 8px; font-size: 0.85rem; color: var(--text-secondary);">
      <a href="/" style="color: var(--primary-light); hover:text-decoration: underline;">Home</a>
      <span>/</span>
      <span style="color: var(--text-primary);">About Us</span>
    </div>
  </div>
</div>

<!-- Services Grid Section -->
<section class="wm-section">
  <div class="wm-container">
    <div class="wm-section-header">
      <span class="wm-eyebrow">Services</span>
      <h2>Designed For Your Convenience</h2>
      <p>We combine cutting-edge technology with world-class hospitality to make flying a breeze.</p>
    </div>

    <div class="wm-grid-3">
      <!-- Fast & Easy Booking -->
      <div class="wm-service-card">
        <div class="wm-service-icon">
          <i class="fas fa-bolt"></i>
        </div>
        <h3>Fast & Easy Booking</h3>
        <p>Search for a flight, pick the seats as you wish, and complete the payment in seconds.</p>
      </div>

      <!-- Global Network -->
      <div class="wm-service-card">
        <div class="wm-service-icon">
          <i class="fas fa-globe"></i>
        </div>
        <h3>Anytime, Anywhere</h3>
        <p>Taking you to destinations all around the globe every day. We're going places together.</p>
      </div>

      <!-- 24/7 Support -->
      <div class="wm-service-card">
        <div class="wm-service-icon">
          <i class="fas fa-headset"></i>
        </div>
        <h3>24/7 Support</h3>
        <p>Our online support desk is available around the clock to answer your questions and concerns.</p>
      </div>
    </div>
  </div>
</section>

<!-- Why Choose Us Section -->
<section class="wm-section" style="background: var(--bg-card2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
  <div class="wm-container">
    <div class="wm-grid-2" style="align-items: center;">
      <div>
        <div class="wm-section-header" style="text-align: left; margin-bottom: 32px;">
          <span class="wm-eyebrow" style="justify-content: flex-start; margin-left: 0;">Why Wing Mate</span>
          <h2 style="margin-left: 0; text-align: left;">Why We Are The Best In The Game</h2>
          <p style="margin-left: 0; text-align: left;">We focus on seamless digital-first workflows and absolute reliability.</p>
        </div>

        <div style="display: flex; flex-direction: column; gap: 16px;">
          <!-- Card 1 -->
          <div class="wm-card" style="padding: 20px;">
            <h4 style="display: flex; align-items: center; gap: 10px; font-size: 1.05rem; margin-bottom: 8px;">
              <i class="fas fa-rocket" style="color: var(--primary-light);"></i> Fast & Frictionless Service
            </h4>
            <p style="font-size: 0.88rem; color: var(--text-secondary); margin: 0;">
              We have streamlined the booking process. Select flights, choose seats dynamically, and pay without hassle.
            </p>
          </div>

          <!-- Card 2 -->
          <div class="wm-card" style="padding: 20px;">
            <h4 style="display: flex; align-items: center; gap: 10px; font-size: 1.05rem; margin-bottom: 8px;">
              <i class="fas fa-laptop" style="color: var(--accent);"></i> Dynamic Online Seat Selection
            </h4>
            <p style="font-size: 0.88rem; color: var(--text-secondary); margin: 0;">
              View and interact with real-time aircraft seat maps. No guest work, pick the window or aisle seat of your choice.
            </p>
          </div>

          <!-- Card 3 -->
          <div class="wm-card" style="padding: 20px;">
            <h4 style="display: flex; align-items: center; gap: 10px; font-size: 1.05rem; margin-bottom: 8px;">
              <i class="fas fa-award" style="color: var(--accent2);"></i> Recognized Industry Standard
            </h4>
            <p style="font-size: 0.88rem; color: var(--text-secondary); margin: 0;">
              Wing Mate is proud to be recognized as the "Best Flight Service" platform by leading industry experts.
            </p>
          </div>
        </div>
      </div>

      <!-- Right Column: Visual Component -->
      <div style="display: flex; justify-content: center; position: relative;">
        <!-- Premium Abstract Badge Panel -->
        <div class="wm-card" style="width: 100%; max-width: 440px; padding: 40px; background: linear-gradient(135deg, var(--bg-card), var(--bg-elevated)); text-align: center; border: 1px solid var(--border-accent);">
          <div style="width: 80px; height: 80px; margin: 0 auto 24px; background: linear-gradient(135deg, var(--primary), var(--accent2)); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: white;">
            ✈
          </div>
          <h3 style="font-size: 1.6rem; margin-bottom: 12px; font-family: var(--font-display);">Wing Mate Premium</h3>
          <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6; margin-bottom: 24px;">
            A professional SaaS-grade aviation reservation and staff coordination platform designed for travelers and airline operators alike.
          </p>
          <div style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; background: rgba(16,185,129,0.15); color: var(--success); border-radius: 50px; font-size: 0.8rem; font-weight: 600;">
            <i class="fas fa-check-circle"></i> Neon & Express Powered
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('_footer', {user}) %>