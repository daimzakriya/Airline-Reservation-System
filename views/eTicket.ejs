<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Ticket Receipt & Itinerary — Wing Mate</title>
    <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
    <!-- Bootstrap 4.3.1 for print styling -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T" crossorigin="anonymous">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/eticket.css">
    
    <style>
      body {
        font-family: 'Inter', sans-serif;
        color: #222;
        background-color: #fff;
      }
      @media print {
        .doNotPrint { display: none !important; }
        div { page-break-inside: avoid; }
        body { background-color: #fff; color: #000; }
        .table { width: 100% !important; border-collapse: collapse !important; }
        h4 { color: #000 !important; }
      }
      .badge-wingmate {
        background-color: #4f6ef7;
        color: #fff;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 600;
      }
      .table-header-custom {
        color: #fff;
        background-color: #4f6ef7 !important;
        padding: 8px 12px;
        font-size: 0.95rem;
        font-weight: 600;
        border-radius: 4px;
      }
    </style>        
</head>
<body onload="window.print()">

  <!-- Print Actions bar (Hidden when printing) -->
  <div class="container p-4 pb-0 doNotPrint">
    <div class="text-center p-3 rounded shadow-sm" style="background-color: #f8f9fa; border: 1px solid #e9ecef;">
      <div class="row align-items-center justify-content-center">
        <div class="col-sm-6 mb-2 mb-sm-0">
          <a class="btn btn-primary btn-block text-white" style="background-color: #4f6ef7; border-color: #4f6ef7;" href="/customer/viewFlights">Book More Flights</a>
        </div>
        <div class="col-sm-6">
          <button onclick="window.print()" class="btn btn-success btn-block">Print / Save as PDF</button>
        </div>
      </div>
    </div>
  </div>
  
  <br>

  <div id="content">
    <% if(bookingDetails && bookingDetails.length != 0) { %>
      <% bookingDetails.forEach(function(booking){ %>
        
        <div class="container mb-5">
          <div class="row align-items-center mb-4">
            <div class="col-sm-3">
              <span class="h3 font-weight-bold" style="color: #4f6ef7;">✈ Wing Mate</span>
            </div>
            <div class="col-sm-9 text-sm-right">
              <h2 class="h4 font-weight-bold text-uppercase text-secondary m-0">Electronic Ticket Receipt & Itinerary</h2>
            </div>
          </div>
          
          <hr>
          
          <p class="text-muted" style="font-size: 0.9rem;">
            Your ticket details are stored securely in our computer reservation system. This e-Ticket receipt / itinerary is your official record. You may need to present this document at airport check-in desks and customs/immigration portals.
          </p>
          
          <div class="card bg-light border-0 mb-4">
            <div class="card-body">
              <h5 class="font-weight-bold text-dark" style="font-size: 0.95rem;">Important Travel Deadlines:</h5>
              <ul class="mb-0 text-secondary" style="font-size: 0.88rem; padding-left: 20px;">
                <li><strong>90 Minutes:</strong> Reach the airport check-in desk no later than 90 minutes prior to departure.</li>
                <li><strong>60 Minutes:</strong> Clear security screening checkpoints no later than 60 minutes before departure.</li>
                <li><strong>45 Minutes:</strong> Boarding starts 45 minutes prior to takeoff; aircraft cabin doors close 20 minutes before departure.</li>
              </ul>
            </div>
          </div>

          <!-- Passenger Info -->
          <div>
            <div class="table-header-custom mb-3">PASSENGER AND RESERVATION DETAILS</div>
            <table class="table table-bordered mb-4">
              <tbody>
                <tr>
                  <td class="font-weight-bold text-secondary" style="width: 30%;">Passenger Name</td>
                  <td class="font-weight-bold"><%= booking.name %></td>
                </tr>
                <tr>
                  <td class="font-weight-bold text-secondary">Booking Reference</td>
                  <td><span class="badge-wingmate">WM-00<%= bookingDetails[0].booking_id %></span></td>
                </tr>
                <tr>
                  <td class="font-weight-bold text-secondary">Reservation Date</td>
                  <td><%= bookingDetails[0].date_of_booking.toString().substring(0,15) %></td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Itinerary Info -->
          <div>
            <div class="table-header-custom mb-3">DETAILED ITINERARY</div>
            <table class="table table-bordered mb-4">
              <thead>
                <tr class="thead-light">
                  <th>Flight</th>
                  <th>Origin</th>
                  <th>Destination</th>
                  <th>Class</th>
                  <th>Seat</th>
                  <th>Duration</th>
                  <th>Aircraft Model</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="font-weight-bold"><%= flightInfo[0].route_id %></td>
                  <td>
                    <strong><%= flightInfo[0].origin %></strong><br>
                    <%= (flightInfo[0].departure_date).toString().substring(0,15) %><br>
                    <%= flightInfo[0].departure_time_utc %> UTC
                  </td>
                  <td>
                    <strong><%= flightInfo[0].destination %></strong><br>
                    <%= (flightInfo[0].arrival_date).toString().substring(0,15) %><br>
                    <%= flightInfo[0].arrival_time_utc %> UTC
                  </td>
                  <td><%= booking.class_name %></td>
                  <td><span class="font-weight-bold text-primary"><%= booking.seat_id %></span></td>
                  <td><%= flightInfo[0].duration.hours %>h <%= flightInfo[0].duration.minutes %>m</td>
                  <td><%= modelDetails.model_name %> (<%= modelDetails.variant %>)</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Fare Details -->
          <div>
            <div class="table-header-custom mb-3">FARE BREAKDOWN</div>
            <table class="table table-bordered mb-4">
              <tbody>
                <tr>
                  <td class="font-weight-bold text-secondary" style="width: 30%;">Seat Price (Base)</td>
                  <td>
                    <% if(flightInfo[1] && flightInfo[1].length != 0) { %>
                      <% flightInfo[1].forEach(function(price){ %>
                        <% if(price.traveler_class_id == booking.class_id) { %>
                          <strong>$<%= price.price %></strong> (Seat price before applicable member discounts)
                        <% } %>
                      <% }); %> 
                    <% } %>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Footer contact info -->
          <div class="text-center p-3 rounded" style="background-color: #f1f3f5; font-size: 0.82rem; color: #495057;">
            <% if(orgDetails && orgDetails.length != 0) { %>
              <strong><%= orgDetails.airline_name %></strong><br> 
              Hotline Support: <%= orgDetails.airline_hotline %> &nbsp;|&nbsp; Official Email: <%= orgDetails.airline_email %><br>
              Headquarters: <%= orgDetails.address_1 %>, <%= orgDetails.address_2 %>, <%= orgDetails.address_3 %>
            <% } %>
          </div>

        </div>
        <p style="page-break-before: always;"></p>
      <% }); %>
    <% } else { %>
      <div class="container text-center py-5">
        <div class="alert alert-warning">No booked tickets found.</div>
      </div>
    <% } %>
  </div>

</body>
</html>
