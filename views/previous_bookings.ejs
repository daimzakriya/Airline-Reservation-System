<%- include('_header', {user}) %>

<!-- Hero Banner Section -->
<section class="wm-hero" style="min-height: 50vh; padding-top: 140px; padding-bottom: 60px;">
  <div class="wm-hero-bg"></div>
  <div class="wm-hero-grid"></div>
  <div class="wm-hero-content" style="max-width: 800px;">
    <div class="wm-hero-pill">
      <span class="wm-hero-pill-dot"></span>
      Travel History
    </div>
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 16px;">My Bookings</h1>
    <p style="margin-bottom: 0;">
      Review your previous reservation records, boarding status, and print e-tickets.
    </p>
  </div>
</section>

<!-- Breadcrumb -->
<div style="background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0;">
  <div class="wm-container">
    <div style="display: flex; gap: 8px; font-size: 0.85rem; color: var(--text-secondary);">
      <a href="/" style="color: var(--primary-light); hover:text-decoration: underline;">Home</a>
      <span>/</span>
      <span style="color: var(--text-primary);">Booking History</span>
    </div>
  </div>
</div>

<!-- Main Table Area -->
<section class="wm-section-sm">
  <div class="wm-container">
    
    <% if(typeof bookingsDetails !== 'undefined' && bookingsDetails && bookingsDetails.length != 0) { %>
      <div class="wm-section-header" style="margin-bottom: 32px; text-align: left;">
        <span class="wm-eyebrow" style="justify-content: flex-start; margin-left: 0;">History Directory</span>
        <h2>Booking Records</h2>
      </div>

      <div class="wm-table-wrap">
        <table class="wm-table">
          <thead>
            <tr>
              <th>Booking ID</th>
              <th>Flight</th>
              <th>Date of Booking</th>
              <th>Origin</th>
              <th>Takeoff (UTC)</th>
              <th>Destination</th>
              <th>Landing (UTC)</th>
              <th>Price</th>
              <th>Status</th>
              <th style="text-align: right;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% bookingsDetails.forEach(function(booking){ %>
              <tr>
                <td>
                  <strong style="color: var(--text-primary);">#00<%= booking.booking_id %></strong>
                </td>
                <td>
                  <span class="wm-badge wm-badge-primary"><%= booking.route_id %></span>
                </td>
                <td>
                  <%= (booking.date_of_booking).toString().substring(0, 15) %>
                </td>
                <td>
                  <strong style="color: var(--text-primary);"><%= booking.origin %></strong>
                </td>
                <td>
                  <%= (booking.departure_date).toString().substring(0, 15) %> <span style="color: var(--primary-light); margin-left: 6px;"><%= booking.departure_time_utc %></span>
                </td>
                <td>
                  <strong style="color: var(--text-primary);"><%= booking.destination %></strong>
                </td>
                <td>
                  <%= (booking.arrival_date).toString().substring(0, 15) %> <span style="color: var(--accent); margin-left: 6px;"><%= booking.arrival_time_utc %></span>
                </td>
                <td>
                  <strong style="color: var(--text-primary); font-size: 0.95rem;">$<%= booking.final_price %></strong>
                </td>
                <td>
                  <% if(booking.state && booking.state.toLowerCase() === 'paid') { %>
                    <span class="wm-badge wm-badge-success"><%= booking.state %></span>
                  <% } else if(booking.state && booking.state.toLowerCase() === 'cancelled') { %>
                    <span class="wm-badge wm-badge-danger"><%= booking.state %></span>
                  <% } else { %>
                    <span class="wm-badge wm-badge-warning"><%= booking.state %></span>
                  <% } %>
                </td>
                <td style="text-align: right;">
                  <form action="/booking/previous" method="POST" style="display: inline-block;">
                    <input type="hidden" name="booking_id" value="<%= booking.booking_id %>">
                    <button type="submit" class="wm-btn wm-btn-ghost wm-btn-sm">
                      <i class="fas fa-info-circle"></i> Info
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

    <% } else { %>
      <div class="wm-card" style="padding: 40px; text-align: center; border-color: var(--border);">
        <div style="width: 56px; height: 56px; background: var(--bg-elevated); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: var(--text-secondary); margin: 0 auto 20px;">
          <i class="fas fa-ticket-alt"></i>
        </div>
        <h3 style="font-size: 1.3rem; margin-bottom: 8px; color: var(--text-primary);">No Booking Records Found</h3>
        <p style="color: var(--text-secondary); max-width: 440px; margin: 0 auto 20px;">
          You haven't made any flight reservations yet. Look up upcoming flights and start planning your next journey.
        </p>
        <a href="/customer/viewFlights" class="wm-btn wm-btn-primary wm-btn-sm">Search Flights Now</a>
      </div>
    <% } %>

    <!-- Upcoming Flights Grid -->
    <% if(typeof upcomingFlights !== 'undefined' && upcomingFlights && upcomingFlights.length != 0) { %>
      <div class="wm-section" id="upcomingFlights" style="padding-top: 64px; border-top: 1px solid var(--border); margin-top: 56px;">
        <div class="wm-section-header">
          <span class="wm-eyebrow">Aviation Schedules</span>
          <h2>Explore Upcoming Flights</h2>
          <p>Book another trip with our exclusive member discount pricing models.</p>
        </div>

        <div class="wm-grid-3">
          <% upcomingFlights.forEach(function(flight){ %>
            <div class="wm-flight-card">
              <div class="wm-flight-card-thumb">
                <img src="<%= flight.destination_image %>" alt="<%= flight.destination %>" onerror="this.src='/assets/images/Logo/w1.png'">
                <div class="wm-flight-card-price">from $<%= flight.price %></div>
              </div>
              <div class="wm-flight-card-body">
                <div class="wm-flight-route">
                  <div class="wm-flight-city"><%= flight.origin %></div>
                  <div class="wm-flight-arrow"><i class="fas fa-plane"></i></div>
                  <div class="wm-flight-city"><%= flight.destination %></div>
                </div>

                <div class="wm-flight-meta">
                  <div class="wm-flight-meta-item">
                    <i class="fas fa-clock"></i> 
                    <span><%= flight.departure_time_utc %> - <%= flight.arrival_time_utc %> UTC</span>
                  </div>
                  <div class="wm-flight-meta-item">
                    <i class="fas fa-calendar-alt"></i> 
                    <span><%= (flight.departure_date).toString().substring(0, 10) %></span>
                  </div>
                </div>

                <form action="/booking" method="POST" style="margin-top: auto;">
                  <input type="hidden" name="schedule_id" value="<%= flight.schedule_id %>">
                  <button type="submit" class="wm-btn wm-btn-primary wm-btn-full">
                    Book Flight
                  </button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

  </div>
</section>

<%- include('_footer', {user}) %>