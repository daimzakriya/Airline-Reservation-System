<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Server Error — Wing Mate</title>
  <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
  <link rel="stylesheet" href="/assets/css/wingmate.css">
</head>
<body>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg-base);background-image:radial-gradient(ellipse 60% 40% at 50% 30%,rgba(239,68,68,0.06),transparent);text-align:center;padding:24px;">
  <div>
    <div style="font-family:var(--font-display);font-size:clamp(5rem,20vw,12rem);font-weight:900;line-height:1;background:linear-gradient(135deg,var(--danger),#ff8c00);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:16px;">500</div>
    <h1 style="font-size:1.8rem;margin-bottom:12px;">Something Went Wrong</h1>
    <p style="color:var(--text-secondary);max-width:440px;margin:0 auto 32px;">We encountered an internal server error. Our team has been notified. Please try again shortly.</p>
    <div style="display:flex;justify-content:center;gap:14px;flex-wrap:wrap;">
      <a href="/" class="wm-btn wm-btn-primary"><i class="fas fa-home"></i> Back to Home</a>
      <button onclick="location.reload()" class="wm-btn wm-btn-outline"><i class="fas fa-sync"></i> Try Again</button>
    </div>
    <div style="margin-top:60px;font-size:0.82rem;color:var(--text-muted);">Error Code: 500 — Internal Server Error</div>
  </div>
</div>
</body>
</html>
