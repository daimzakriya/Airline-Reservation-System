<%- include('_header', {user}) %>

<!-- Hero Banner Section -->
<section class="wm-hero" style="min-height: 50vh; padding-top: 140px; padding-bottom: 60px;">
  <div class="wm-hero-bg"></div>
  <div class="wm-hero-grid"></div>
  <div class="wm-hero-content" style="max-width: 800px;">
    <div class="wm-hero-pill">
      <span class="wm-hero-pill-dot"></span>
      Get In Touch
    </div>
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 16px;">We're Here to Help</h1>
    <p style="margin-bottom: 0;">
      Have a question about flights, bookings, or scheduling? Contact our team and we'll respond as soon as possible.
    </p>
  </div>
</section>

<!-- Breadcrumb -->
<div style="background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0;">
  <div class="wm-container">
    <div style="display: flex; gap: 8px; font-size: 0.85rem; color: var(--text-secondary);">
      <a href="/" style="color: var(--primary-light); hover:text-decoration: underline;">Home</a>
      <span>/</span>
      <span style="color: var(--text-primary);">Contact</span>
    </div>
  </div>
</div>

<!-- Contact Info Grid -->
<section class="wm-section">
  <div class="wm-container">
    <div class="wm-section-header">
      <span class="wm-eyebrow">Office Info</span>
      <h2>Office Contact Details</h2>
      <p>Reach us through our helpline, official emails, or visit our central headquarters.</p>
    </div>

    <div class="wm-grid-3">
      <!-- Address -->
      <div class="wm-card" style="text-align: center; padding: 40px 24px;">
        <div style="width: 56px; height: 56px; background: rgba(79,110,247,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: var(--primary-light); margin: 0 auto 20px;">
          <i class="fas fa-map-marker-alt"></i>
        </div>
        <h3 style="font-size: 1.15rem; margin-bottom: 16px;">Office Address</h3>
        <div style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;">
          <p style="margin-bottom: 4px;"><%= contactDetails.address_1 %></p>
          <p style="margin-bottom: 4px;"><%= contactDetails.address_2 %></p>
          <p style="margin-bottom: 0;"><%= contactDetails.address_3 %></p>
        </div>
      </div>

      <!-- Phone -->
      <div class="wm-card" style="text-align: center; padding: 40px 24px;">
        <div style="width: 56px; height: 56px; background: rgba(0,210,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: var(--accent); margin: 0 auto 20px;">
          <i class="fas fa-phone-alt"></i>
        </div>
        <h3 style="font-size: 1.15rem; margin-bottom: 16px;">Phone Number</h3>
        <div style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;">
          <p style="font-weight: 600; color: var(--text-primary); font-size: 1rem; margin-bottom: 4px;"><%= contactDetails.airline_hotline %></p>
          <p style="margin-bottom: 0;">24/7 Hotline Support</p>
        </div>
      </div>

      <!-- Email -->
      <div class="wm-card" style="text-align: center; padding: 40px 24px;">
        <div style="width: 56px; height: 56px; background: rgba(168,85,247,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: var(--accent2); margin: 0 auto 20px;">
          <i class="fas fa-envelope"></i>
        </div>
        <h3 style="font-size: 1.15rem; margin-bottom: 16px;">Email Address</h3>
        <div style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;">
          <p style="font-weight: 600; color: var(--text-primary); font-size: 1rem; margin-bottom: 4px; text-transform: lowercase;"><%= contactDetails.airline_email %></p>
          <p style="margin-bottom: 0;">Customer Relations Team</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Authors Section -->
<section class="wm-section" style="background: var(--bg-card2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
  <div class="wm-container">
    <div class="wm-section-header">
      <span class="wm-eyebrow">The Architect</span>
      <h2>Platform Architect</h2>
      <p>Meet the engineer and visionary behind the Wing Mate reservation platform.</p>
    </div>

    <!-- Single architect card, centered, clickable -->
    <div style="display: flex; justify-content: center;">
      <a href="/creator" style="text-decoration: none; color: inherit;" id="architect-card-link">
        <div class="wm-card" style="width: 340px; text-align: center; padding: 36px 28px; display: flex; flex-direction: column; align-items: center; transition: transform 0.25s ease, box-shadow 0.25s ease; cursor: pointer;"
          onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 20px 48px rgba(79,110,247,0.25)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='';">
          <!-- Photo -->
          <div style="width: 160px; height: 160px; border-radius: 50%; overflow: hidden; border: 3px solid var(--border-accent); margin-bottom: 20px; background: var(--bg-elevated); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 0 6px rgba(79,110,247,0.12);">
            <img src="/assets/images/GOATs/daim.jpg" alt="Daim Bin Zakriya" style="width: 100%; height: 100%; object-fit: cover; object-position: top;">
          </div>
          <h3 style="font-size: 1.25rem; margin-bottom: 4px;">Daim Bin Zakriya</h3>
          <p style="font-size: 0.85rem; color: var(--primary-light); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 12px;">Full-Stack Architect</p>
          <p style="font-size: 0.88rem; color: var(--text-secondary); margin: 0 0 18px;">Designed and built the complete Wing Mate platform — database, backend, and frontend — end to end.</p>
          <span class="wm-badge wm-badge-primary" style="gap: 6px;"><i class="fas fa-arrow-right"></i> View Profile</span>
        </div>
      </a>
    </div>
  </div>
</section>

<%- include('_footer', {user}) %>