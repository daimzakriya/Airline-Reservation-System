<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Wing Mate</title>
  <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
  <link rel="stylesheet" href="/assets/css/wingmate.css">
</head>
<body>
<div class="wm-staff-layout">

  <!-- Sidebar -->
  <aside class="wm-sidebar">
    <div class="wm-sidebar-logo">
      <span class="logo-icon">✈</span>
      Wing Mate
    </div>
    <div class="wm-sidebar-section-title">Admin</div>
    <a href="/staff/admin" class="wm-sidebar-link active" id="sidebar-admin-home">
      <i class="fas fa-tachometer-alt"></i> Dashboard
    </a>
    <div class="wm-sidebar-section-title" style="margin-top:12px;">Account</div>
    <a href="/staff/edit_profile" class="wm-sidebar-link" id="sidebar-edit-profile">
      <i class="fas fa-user-edit"></i> Edit Profile
    </a>
    <div class="wm-sidebar-bottom">
      <a href="/staff/logout" class="wm-sidebar-link" id="sidebar-logout" style="color:var(--danger);">
        <i class="fas fa-sign-out-alt"></i> Log Out
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="wm-staff-content">
    <div class="wm-staff-topbar">
      <div>
        <h1>Admin Dashboard</h1>
        <p style="color:var(--text-muted);font-size:0.88rem;margin-top:4px;">Manage staff account approvals</p>
      </div>
      <div class="wm-user-pill">
        <div class="wm-user-avatar"><%= user.staffData.first_name.charAt(0).toUpperCase() %></div>
        <span class="wm-user-name"><%= user.staffData.first_name %> <%= user.staffData.last_name %></span>
        <span class="wm-badge wm-badge-accent" style="margin-left:4px;">Admin</span>
      </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="wm-alert wm-alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="wm-alert wm-alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <!-- Stats -->
    <div class="wm-grid-4" style="margin-bottom:32px;">
      <div class="wm-stat-card">
        <div class="wm-stat-icon wm-stat-icon-amber"><i class="fas fa-user-clock"></i></div>
        <div>
          <div class="wm-stat-value"><%= typeof unverifiedStaff !== 'undefined' ? unverifiedStaff.length : 0 %></div>
          <div class="wm-stat-label">Pending Approvals</div>
        </div>
      </div>
    </div>

    <!-- Pending Staff -->
    <div class="wm-card" style="padding:0;overflow:hidden;">
      <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
        <h3 style="font-size:1rem;">Pending Staff Approvals</h3>
        <% if (typeof unverifiedStaff !== 'undefined' && unverifiedStaff.length > 0) { %>
          <span class="wm-badge wm-badge-warning"><%= unverifiedStaff.length %> pending</span>
        <% } %>
      </div>

      <% if (!unverifiedStaff || unverifiedStaff.length === 0) { %>
        <div style="text-align:center;padding:60px 24px;color:var(--text-muted);">
          <i class="fas fa-check-circle" style="font-size:2.5rem;margin-bottom:16px;display:block;color:var(--success);opacity:0.5;"></i>
          <p>No pending approvals. All staff accounts are verified.</p>
        </div>
      <% } else { %>
      <div class="wm-table-wrap" style="border:none;border-radius:0;">
        <table class="wm-table">
          <thead>
            <tr>
              <th>Employee ID</th>
              <th>Name</th>
              <th>Role</th>
              <th>Email</th>
              <th>Country</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% unverifiedStaff.forEach(function(staff) { %>
            <tr>
              <td><code style="background:var(--bg-elevated);padding:2px 8px;border-radius:4px;font-size:0.82rem;"><%= staff.emp_id %></code></td>
              <td><strong><%= staff.first_name %> <%= staff.last_name %></strong></td>
              <td><span class="wm-badge wm-badge-primary"><%= staff.category %></span></td>
              <td style="color:var(--text-muted);"><%= staff.email %></td>
              <td><%= staff.country %></td>
              <td>
                <div style="display:flex;gap:8px;">
                  <form action="/staff/admin/verify_staff" method="POST" style="margin:0;">
                    <input type="hidden" name="empId" value="<%= staff.emp_id %>">
                    <button type="submit" class="wm-btn wm-btn-success wm-btn-sm" id="verify-<%= staff.emp_id %>">
                      <i class="fas fa-check"></i> Approve
                    </button>
                  </form>
                  <form action="/staff/admin/delete_staff" method="POST" style="margin:0;" onsubmit="return confirm('Reject and delete this account?')">
                    <input type="hidden" name="empId" value="<%= staff.emp_id %>">
                    <button type="submit" class="wm-btn wm-btn-danger wm-btn-sm" id="reject-<%= staff.emp_id %>">
                      <i class="fas fa-times"></i> Reject
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
