<%- include('_header', {user}) %>

<!-- Hero Banner Section -->
<section class="wm-hero" style="min-height: 50vh; padding-top: 140px; padding-bottom: 60px;">
  <div class="wm-hero-bg"></div>
  <div class="wm-hero-grid"></div>
  <div class="wm-hero-content" style="max-width: 800px;">
    <div class="wm-hero-pill">
      <span class="wm-hero-pill-dot"></span>
      Account Control
    </div>
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 16px;">Edit Profile</h1>
    <p style="margin-bottom: 0;">
      Keep your passport details, email notification configurations, and security credentials up to date.
    </p>
  </div>
</section>

<!-- Breadcrumb -->
<div style="background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0;">
  <div class="wm-container">
    <div style="display: flex; gap: 8px; font-size: 0.85rem; color: var(--text-secondary);">
      <a href="/" style="color: var(--primary-light); hover:text-decoration: underline;">Home</a>
      <span>/</span>
      <span style="color: var(--text-primary);">Account Settings</span>
    </div>
  </div>
</div>

<section class="wm-section-sm">
  <div class="wm-container">
    <div style="display: grid; grid-template-columns: 1fr; gap: 32px; max-width: 720px; margin: 0 auto;">

      <% if(typeof registrationError !== 'undefined' && registrationError) { %>
        <div class="wm-alert wm-alert-error">
          <i class="fas fa-exclamation-circle"></i> <%= registrationError %>
        </div>
      <% } %>

      <!-- Form 1: Edit Profile Details -->
      <div class="wm-card" style="padding: 32px;">
        <h3 style="font-size: 1.3rem; margin-bottom: 24px; font-family: var(--font-display); border-bottom: 1px solid var(--border); padding-bottom: 12px; display: flex; align-items: center; gap: 10px;">
          <i class="fas fa-user-circle" style="color: var(--primary-light);"></i> Passenger Profile Details
        </h3>

        <form id="editProfile">
          <input type="hidden" id="custID" value="<%= user.customerData.customer_id %>">

          <div class="wm-form-group">
            <label>Registered Email</label>
            <input type="email" class="wm-input" id="editEmail" value="<%= user.customerData.email %>" style="opacity: 0.7;" disabled>
            <small style="color: var(--text-muted); margin-top: 4px; display: block;">Email addresses cannot be modified online for security reasons.</small>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="wm-form-group">
              <label>First Name</label>
              <input type="text" class="wm-input" name="firstName" id="editFirstName" required value="<%= user.customerData.first_name %>">
            </div>
            <div class="wm-form-group">
              <label>Last Name</label>
              <input type="text" class="wm-input" name="lastName" id="editLastName" required value="<%= user.customerData.last_name %>">
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="wm-form-group">
              <label>Date of Birth</label>
              <input type="date" class="wm-input" id="editDob" value="<%= user.customerData.dob.substring(0, 10) %>" required>
            </div>
            <div class="wm-form-group">
              <label>Gender</label>
              <select class="wm-select select-bar" id="editGender" required>
                <option value="">- Select Gender -</option>
                <option value="Male" <%= user.customerData.gender==='Male' ? 'selected' : '' %>>Male</option>
                <option value="Female" <%= user.customerData.gender==='Female' ? 'selected' : '' %>>Female</option>
                <option value="Other" <%= user.customerData.gender==='Other' ? 'selected' : '' %>>Other</option>
              </select>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="wm-form-group">
              <label>Contact Number</label>
              <input type="tel" class="wm-input" id="editContactNo" value="<%= user.customerData.contact_no %>" required>
            </div>
            <div class="wm-form-group">
              <label>Passport Number</label>
              <input type="text" class="wm-input" id="editPassportNo" value="<%= user.customerData.passport_no %>" required>
            </div>
          </div>

          <div class="wm-form-group">
            <label>Address Line 1</label>
            <input type="text" class="wm-input" name="addressLine1" id="editAddressLine1" required value="<%= user.customerData.address_line1 %>" style="margin-bottom: 8px;">
            <label>Address Line 2</label>
            <input type="text" class="wm-input" name="addressLine2" id="editAddressLine2" required value="<%= user.customerData.address_line2 %>">
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="wm-form-group">
              <label>City</label>
              <input type="text" class="wm-input" name="city" id="editCity" required value="<%= user.customerData.city %>">
            </div>
            <div class="wm-form-group">
              <label>Country</label>
              <input type="text" class="wm-input" name="country" id="editCountry" required value="<%= user.customerData.country %>">
            </div>
          </div>

          <div style="text-align: center; margin-top: 32px;" id="submitButton">
            <button class="wm-btn wm-btn-primary" type="submit" style="min-width: 180px;">Save Profile Changes</button>
          </div>
        </form>
      </div>

      <!-- Form 2: Change Password -->
      <div class="wm-card" style="padding: 32px;">
        <h3 style="font-size: 1.3rem; margin-bottom: 24px; font-family: var(--font-display); border-bottom: 1px solid var(--border); padding-bottom: 12px; display: flex; align-items: center; gap: 10px;">
          <i class="fas fa-key" style="color: var(--accent);"></i> Account Password Update
        </h3>

        <form id="changePassword">
          <input type="hidden" id="custID" value="<%= user.customerData.customer_id %>">

          <div class="wm-form-group">
            <label>Current Password</label>
            <input type="password" class="wm-input" id="currentPassword" placeholder="••••••••" required>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="wm-form-group">
              <label>New Password</label>
              <input type="password" class="wm-input" name="newPassword1" id="newPassword1" placeholder="••••••••" required>
            </div>
            <div class="wm-form-group">
              <label>Re-type New Password</label>
              <input type="password" class="wm-input" name="newPassword2" id="newPassword2" placeholder="••••••••" required>
            </div>
          </div>

          <div style="text-align: center; margin-top: 32px;" id="changePasswordButton">
            <button class="wm-btn wm-btn-ghost" type="submit" style="min-width: 180px;">Update Password</button>
          </div>
        </form>
      </div>

    </div>
  </div>
</section>

<%- include('_footer', {user}) %>
