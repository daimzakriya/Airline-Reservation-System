<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>General Staff — Wing Mate</title>
  <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
  <link rel="stylesheet" href="/assets/css/wingmate.css">
</head>
<body>
<div class="wm-staff-layout">
  <aside class="wm-sidebar">
    <div class="wm-sidebar-logo"><span class="logo-icon">✈</span>Wing Mate</div>
    <div class="wm-sidebar-section-title">Operations</div>
    <a href="/staff/general" class="wm-sidebar-link active" id="sidebar-home"><i class="fas fa-home"></i> Home</a>
    <a href="/staff/general/arrivedFlights" class="wm-sidebar-link" id="sidebar-arrived"><i class="fas fa-plane-arrival"></i> Arrived Flights</a>
    <a href="/staff/general/upcomingFlightsMain" class="wm-sidebar-link" id="sidebar-upcoming"><i class="fas fa-plane-departure"></i> Upcoming Flights</a>
    <div class="wm-sidebar-section-title" style="margin-top:12px;">Account</div>
    <a href="/staff/edit_profile" class="wm-sidebar-link" id="sidebar-profile"><i class="fas fa-user-edit"></i> Edit Profile</a>
    <div class="wm-sidebar-bottom">
      <a href="/staff/logout" class="wm-sidebar-link" id="sidebar-logout" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Log Out</a>
    </div>
  </aside>

  <main class="wm-staff-content">
    <div class="wm-staff-topbar">
      <div>
        <h1>Operations Dashboard</h1>
        <p style="color:var(--text-muted);font-size:0.88rem;margin-top:4px;">Airport: <strong style="color:var(--primary-light);"><%= user.staffData.assigned_airport || 'Unassigned' %></strong></p>
      </div>
      <div class="wm-user-pill">
        <div class="wm-user-avatar"><%= user.staffData.first_name.charAt(0).toUpperCase() %></div>
        <span class="wm-user-name"><%= user.staffData.first_name %></span>
        <span class="wm-badge wm-badge-muted" style="margin-left:4px;">General</span>
      </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="wm-alert wm-alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="wm-alert wm-alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <div class="wm-grid-2" style="gap:28px;">
      <!-- Incoming Flights -->
      <div class="wm-card" style="padding:0;overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;">
          <i class="fas fa-plane-arrival" style="color:var(--success);"></i>
          <h3 style="font-size:0.95rem;">Incoming Flights — Pending Arrival</h3>
        </div>
        <% if (!incomingFlights || incomingFlights.length === 0) { %>
          <div style="text-align:center;padding:40px;color:var(--text-muted);font-size:0.88rem;">
            <i class="fas fa-check" style="font-size:1.5rem;margin-bottom:10px;display:block;color:var(--success);opacity:0.5;"></i>
            No incoming flights pending
          </div>
        <% } else { %>
          <div style="overflow-x:auto;">
          <table class="wm-table">
            <thead><tr><th>Schedule</th><th>Route</th><th>ETA</th><th>Action</th></tr></thead>
            <tbody>
              <% incomingFlights.forEach(function(flight) { %>
              <tr>
                <td><code style="background:var(--bg-elevated);padding:2px 8px;border-radius:4px;font-size:0.8rem;">#<%= flight.schedule_id %></code></td>
                <td><%= flight.origin %> → <%= flight.destination %></td>
                <td style="color:var(--text-muted);font-size:0.82rem;"><%= flight.arrival_time_utc %></td>
                <td>
                  <form action="/staff/general/markArrival" method="POST" style="margin:0;">
                    <input type="hidden" name="arrival_schedule_id" value="<%= flight.schedule_id %>">
                    <button type="submit" class="wm-btn wm-btn-success wm-btn-sm" id="mark-arrived-<%= flight.schedule_id %>">
                      <i class="fas fa-check"></i> Mark Arrived
                    </button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          </div>
        <% } %>
      </div>

      <!-- Departing Flights -->
      <div class="wm-card" style="padding:0;overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;">
          <i class="fas fa-plane-departure" style="color:var(--primary-light);"></i>
          <h3 style="font-size:0.95rem;">Departing Flights — Pending Departure</h3>
        </div>
        <% if (!departingFlights || departingFlights.length === 0) { %>
          <div style="text-align:center;padding:40px;color:var(--text-muted);font-size:0.88rem;">
            <i class="fas fa-check" style="font-size:1.5rem;margin-bottom:10px;display:block;color:var(--primary-light);opacity:0.5;"></i>
            No departing flights pending
          </div>
        <% } else { %>
          <div style="overflow-x:auto;">
          <table class="wm-table">
            <thead><tr><th>Schedule</th><th>Route</th><th>ETD</th><th>Action</th></tr></thead>
            <tbody>
              <% departingFlights.forEach(function(flight) { %>
              <tr>
                <td><code style="background:var(--bg-elevated);padding:2px 8px;border-radius:4px;font-size:0.8rem;">#<%= flight.schedule_id %></code></td>
                <td><%= flight.origin %> → <%= flight.destination %></td>
                <td style="color:var(--text-muted);font-size:0.82rem;"><%= flight.departure_time_utc %></td>
                <td>
                  <form action="/staff/general/markDeparture" method="POST" style="margin:0;">
                    <input type="hidden" name="departing_schedule_id" value="<%= flight.schedule_id %>">
                    <button type="submit" class="wm-btn wm-btn-primary wm-btn-sm" id="mark-departed-<%= flight.schedule_id %>">
                      <i class="fas fa-plane-departure"></i> Mark Departed
                    </button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</div>
</body>
</html>
