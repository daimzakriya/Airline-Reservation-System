<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Flights — Wing Mate Manager</title>
  <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
  <link rel="stylesheet" href="/assets/css/wingmate.css">
</head>
<body>
<div class="wm-staff-layout">
  <aside class="wm-sidebar">
    <div class="wm-sidebar-logo"><span class="logo-icon">✈</span>Wing Mate</div>
    <div class="wm-sidebar-section-title">Manager</div>
    <a href="/staff/manager" class="wm-sidebar-link" id="sidebar-home"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    <a href="/staff/manager/all_flights" class="wm-sidebar-link active" id="sidebar-flights"><i class="fas fa-plane"></i> All Flights</a>
    <a href="/staff/manager/all_general_staff" class="wm-sidebar-link" id="sidebar-staff"><i class="fas fa-users"></i> Staff Directory</a>
    <a href="/staff/manager/reports" class="wm-sidebar-link" id="sidebar-reports"><i class="fas fa-chart-bar"></i> Reports</a>
    <a href="/staff/edit_profile" class="wm-sidebar-link" id="sidebar-profile"><i class="fas fa-user-edit"></i> Edit Profile</a>
    <div class="wm-sidebar-bottom"><a href="/staff/logout" class="wm-sidebar-link" id="sidebar-logout" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Log Out</a></div>
  </aside>
  <main class="wm-staff-content">
    <div class="wm-staff-topbar">
      <div><h1>All Flights</h1><p style="color:var(--text-muted);font-size:0.88rem;margin-top:4px;">Network-wide flight status overview</p></div>
      <div class="wm-user-pill">
        <div class="wm-user-avatar"><%= user.staffData.first_name.charAt(0).toUpperCase() %></div>
        <span class="wm-user-name"><%= user.staffData.first_name %></span>
      </div>
    </div>

    <!-- Tabs -->
    <div class="wm-tabs" id="flight-tabs">
      <div class="wm-tab active" onclick="showTab('upcoming')" id="tab-upcoming">Upcoming (<%= allUpcomingFlights ? allUpcomingFlights.length : 0 %>)</div>
      <div class="wm-tab" onclick="showTab('ongoing')" id="tab-ongoing">In-Air (<%= ongoingAllFlights ? ongoingAllFlights.length : 0 %>)</div>
      <div class="wm-tab" onclick="showTab('arrived')" id="tab-arrived">Arrived (<%= allArrivedFlights ? allArrivedFlights.length : 0 %>)</div>
    </div>

    <!-- Upcoming -->
    <div id="tab-content-upcoming">
      <div class="wm-card" style="padding:0;overflow:hidden;">
        <% if (!allUpcomingFlights || allUpcomingFlights.length === 0) { %>
          <div style="text-align:center;padding:48px;color:var(--text-muted);">No upcoming flights</div>
        <% } else { %>
        <table class="wm-table"><thead><tr><th>#</th><th>Route</th><th>Departure Date</th><th>Departure Time</th><th>Aircraft</th><th>Status</th></tr></thead>
        <tbody>
          <% allUpcomingFlights.forEach(function(f) { %>
          <tr>
            <td><code style="background:var(--bg-elevated);padding:2px 8px;border-radius:4px;font-size:0.8rem;">#<%= f.schedule_id %></code></td>
            <td><strong><%= f.origin %></strong> → <strong><%= f.destination %></strong></td>
            <td style="color:var(--text-muted);font-size:0.82rem;"><%= new Date(f.departure_date).toLocaleDateString() %></td>
            <td style="color:var(--text-muted);font-size:0.82rem;"><%= f.departure_time_utc %></td>
            <td style="color:var(--text-muted);font-size:0.82rem;">#<%= f.aircraft_id %></td>
            <td><span class="wm-badge wm-badge-primary">Scheduled</span></td>
          </tr>
          <% }); %>
        </tbody></table>
        <% } %>
      </div>
    </div>

    <!-- Ongoing (In-Air) -->
    <div id="tab-content-ongoing" class="wm-hidden">
      <div class="wm-card" style="padding:0;overflow:hidden;">
        <% if (!ongoingAllFlights || ongoingAllFlights.length === 0) { %>
          <div style="text-align:center;padding:48px;color:var(--text-muted);">No flights currently in-air</div>
        <% } else { %>
        <table class="wm-table"><thead><tr><th>#</th><th>Route</th><th>Departed</th><th>Status</th></tr></thead>
        <tbody>
          <% ongoingAllFlights.forEach(function(f) { %>
          <tr>
            <td><code style="background:var(--bg-elevated);padding:2px 8px;border-radius:4px;font-size:0.8rem;">#<%= f.schedule_id %></code></td>
            <td><strong><%= f.origin %></strong> → <strong><%= f.destination %></strong></td>
            <td style="color:var(--text-muted);font-size:0.82rem;"><%= f.actual_departed ? new Date(f.actual_departed).toLocaleString() : '—' %></td>
            <td><span class="wm-badge wm-badge-warning"><i class="fas fa-circle" style="font-size:0.5em;"></i> In-Air</span></td>
          </tr>
          <% }); %>
        </tbody></table>
        <% } %>
      </div>
    </div>

    <!-- Arrived -->
    <div id="tab-content-arrived" class="wm-hidden">
      <div class="wm-card" style="padding:0;overflow:hidden;">
        <% if (!allArrivedFlights || allArrivedFlights.length === 0) { %>
          <div style="text-align:center;padding:48px;color:var(--text-muted);">No arrived flights</div>
        <% } else { %>
        <table class="wm-table"><thead><tr><th>#</th><th>Route</th><th>Arrival Date</th><th>Actual Arrival</th><th>Status</th></tr></thead>
        <tbody>
          <% allArrivedFlights.forEach(function(f) { %>
          <tr>
            <td><code style="background:var(--bg-elevated);padding:2px 8px;border-radius:4px;font-size:0.8rem;">#<%= f.schedule_id %></code></td>
            <td><strong><%= f.origin %></strong> → <strong><%= f.destination %></strong></td>
            <td style="color:var(--text-muted);font-size:0.82rem;"><%= new Date(f.arrival_date).toLocaleDateString() %></td>
            <td style="color:var(--text-muted);font-size:0.82rem;"><%= f.actual_arrival ? new Date(f.actual_arrival).toLocaleString() : '—' %></td>
            <td><span class="wm-badge wm-badge-success"><i class="fas fa-check" style="font-size:0.6em;"></i> Landed</span></td>
          </tr>
          <% }); %>
        </tbody></table>
        <% } %>
      </div>
    </div>
  </main>
</div>
<script>
function showTab(tab) {
  ['upcoming','ongoing','arrived'].forEach(t => {
    document.getElementById('tab-content-' + t).classList.add('wm-hidden');
    document.getElementById('tab-' + t).classList.remove('active');
  });
  document.getElementById('tab-content-' + tab).classList.remove('wm-hidden');
  document.getElementById('tab-' + tab).classList.add('active');
}
</script>
</body>
</html>
