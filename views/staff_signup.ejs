<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff Registration — Wing Mate</title>
  <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
  <link rel="stylesheet" href="/assets/css/wingmate.css">
</head>
<body>
<div class="wm-auth-wrap" style="padding:60px 24px;">
  <div class="wm-auth-card" style="max-width:580px;">
    <div class="wm-auth-logo">
      <div class="logo" style="font-family:var(--font-display);font-size:1.8rem;font-weight:800;background:linear-gradient(135deg,#fff,var(--primary-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">✈ Wing Mate</div>
      <div style="margin-top:6px;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);font-weight:600;">Staff Portal</div>
    </div>

    <h2>Staff Registration</h2>
    <p class="sub">Create your employee account — admin accounts are auto-verified</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="wm-alert wm-alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="wm-alert wm-alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <form action="/staff/register" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="wm-form-group">
          <label>First Name</label>
          <input class="wm-input" type="text" name="firstName" placeholder="John" value="<%= typeof firstName !== 'undefined' ? firstName : '' %>" required>
        </div>
        <div class="wm-form-group">
          <label>Last Name</label>
          <input class="wm-input" type="text" name="lastName" placeholder="Doe" value="<%= typeof lastName !== 'undefined' ? lastName : '' %>" required>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="wm-form-group">
          <label>Employee ID</label>
          <input class="wm-input" type="text" name="empId" placeholder="EMP001" value="<%= typeof empId !== 'undefined' ? empId : '' %>" required>
        </div>
        <div class="wm-form-group">
          <label>Staff Category</label>
          <select class="wm-select" name="category" required>
            <option value="">Select role</option>
            <option value="manager" <%= typeof category !== 'undefined' && category === 'manager' ? 'selected' : '' %>>Manager</option>
            <option value="general" <%= typeof category !== 'undefined' && category === 'general' ? 'selected' : '' %>>General Staff</option>
          </select>
        </div>
      </div>

      <div class="wm-form-group">
        <label>Email Address</label>
        <input class="wm-input" type="email" name="email" placeholder="staff@wingmate.com" value="<%= typeof email !== 'undefined' ? email : '' %>" required>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="wm-form-group">
          <label>Password</label>
          <input class="wm-input" type="password" name="password" placeholder="Min 8 characters" required>
        </div>
        <div class="wm-form-group">
          <label>Confirm Password</label>
          <input class="wm-input" type="password" name="confirmPassword" placeholder="Repeat password" required>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="wm-form-group">
          <label>Contact Number</label>
          <input class="wm-input" type="tel" name="contactNo" placeholder="+1-555-0100" value="<%= typeof contactNo !== 'undefined' ? contactNo : '' %>" required>
        </div>
        <div class="wm-form-group">
          <label>Date of Birth</label>
          <input class="wm-input" type="date" name="dob" value="<%= typeof dob !== 'undefined' ? dob : '' %>" required>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="wm-form-group">
          <label>Gender</label>
          <select class="wm-select" name="gender" required>
            <option value="">Select gender</option>
            <option value="Male" <%= typeof gender !== 'undefined' && gender === 'Male' ? 'selected' : '' %>>Male</option>
            <option value="Female" <%= typeof gender !== 'undefined' && gender === 'Female' ? 'selected' : '' %>>Female</option>
            <option value="Other" <%= typeof gender !== 'undefined' && gender === 'Other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>
        <div class="wm-form-group">
          <label>Country</label>
          <input class="wm-input" type="text" name="country" placeholder="Pakistan" value="<%= typeof country !== 'undefined' ? country : '' %>" required>
        </div>
      </div>

      <div class="wm-form-group">
        <label>Assigned Airport</label>
        <select class="wm-select" name="airport">
          <option value="">Select airport (optional)</option>
          <% if (typeof airportCodes !== 'undefined' && airportCodes) { %>
            <% airportCodes.forEach(function(ap) { %>
              <option value="<%= ap.airport_code %>" <%= typeof airport !== 'undefined' && airport === ap.airport_code ? 'selected' : '' %>>
                <%= ap.airport_code %> — <%= ap.name %>
              </option>
            <% }); %>
          <% } %>
        </select>
      </div>



      <button type="submit" class="wm-btn wm-btn-primary wm-btn-full" id="staff-register-btn">
        <i class="fas fa-user-plus"></i> Create Staff Account
      </button>
    </form>

    <div class="wm-auth-footer">
      Already registered? <a href="/staff/login">Sign in</a>
    </div>
    <div class="wm-auth-footer" style="margin-top:10px;">
      <a href="/" style="color:var(--text-muted);">← Back to main site</a>
    </div>
  </div>
</div>
</body>
</html>
