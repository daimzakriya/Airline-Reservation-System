<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reports — Wing Mate Manager</title>
  <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
  <link rel="stylesheet" href="/assets/css/wingmate.css">
</head>
<body>
<div class="wm-staff-layout">
  <aside class="wm-sidebar">
    <div class="wm-sidebar-logo"><span class="logo-icon">✈</span>Wing Mate</div>
    <a href="/staff/manager" class="wm-sidebar-link" id="sidebar-home"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    <a href="/staff/manager/all_flights" class="wm-sidebar-link" id="sidebar-flights"><i class="fas fa-plane"></i> All Flights</a>
    <a href="/staff/manager/all_general_staff" class="wm-sidebar-link" id="sidebar-staff"><i class="fas fa-users"></i> Staff Directory</a>
    <a href="/staff/manager/reports" class="wm-sidebar-link active" id="sidebar-reports"><i class="fas fa-chart-bar"></i> Reports</a>
    <a href="/staff/edit_profile" class="wm-sidebar-link" id="sidebar-profile"><i class="fas fa-user-edit"></i> Edit Profile</a>
    <div class="wm-sidebar-bottom"><a href="/staff/logout" class="wm-sidebar-link" id="sidebar-logout" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Log Out</a></div>
  </aside>
  <main class="wm-staff-content">
    <div class="wm-staff-topbar">
      <div><h1>Reports & Analytics</h1><p style="color:var(--text-muted);font-size:0.88rem;margin-top:4px;">Network performance insights</p></div>
    </div>
    <% if (typeof error !== 'undefined' && error) { %><div class="wm-alert wm-alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>

    <div class="wm-grid-2" style="gap:24px;align-items:start;">

      <!-- Revenue by Model -->
      <div class="wm-card">
        <h3 style="font-size:0.95rem;margin-bottom:16px;display:flex;align-items:center;gap:8px;"><i class="fas fa-dollar-sign" style="color:var(--success);"></i> Revenue by Aircraft Model</h3>
        <% if (models && models.length > 0) { %>
          <% models.forEach(function(m) { %>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);">
            <div>
              <div style="font-weight:600;font-size:0.88rem;"><%= m.model_name %> <%= m.variant %></div>
              <div style="font-size:0.78rem;color:var(--text-muted);"><%= m.manufacturer_name %></div>
            </div>
            <div style="font-family:var(--font-display);font-weight:700;color:var(--success);">$<%= parseFloat(m.total_revenue || 0).toLocaleString() %></div>
          </div>
          <% }); %>
        <% } else { %>
          <p style="color:var(--text-muted);text-align:center;padding:24px 0;">No revenue data available</p>
        <% } %>
      </div>

      <!-- Report Tools -->
      <div style="display:flex;flex-direction:column;gap:20px;">

        <!-- Passenger Count -->
        <div class="wm-card">
          <h3 style="font-size:0.9rem;margin-bottom:14px;display:flex;align-items:center;gap:8px;"><i class="fas fa-users" style="color:var(--primary-light);"></i> Passenger Count by Destination</h3>
          <form action="/staff/manager/passengerCount" method="POST">
            <div class="wm-form-group">
              <label>Airport</label>
              <select class="wm-select" name="passenger_count_airport_code">
                <option value="">Select airport</option>
                <% if (airportCodes) { airportCodes.forEach(function(ap) { %>
                  <option value="<%= ap.airport_code %>"><%= ap.airport_code %> — <%= ap.name %></option>
                <% }); } %>
              </select>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div class="wm-form-group"><label>Start Date</label><input class="wm-input" type="date" name="passenger_count_start_date" required></div>
              <div class="wm-form-group"><label>End Date</label><input class="wm-input" type="date" name="passenger_count_end_date" required></div>
            </div>
            <% if (passenger_count_to_dest) { %><div class="wm-alert wm-alert-info" style="margin-bottom:12px;"><i class="fas fa-info-circle"></i> <%- passenger_count_to_dest %></div><% } %>
            <button type="submit" class="wm-btn wm-btn-primary wm-btn-sm" id="passenger-count-btn"><i class="fas fa-search"></i> Generate Report</button>
          </form>
        </div>

        <!-- Passenger Details -->
        <div class="wm-card">
          <h3 style="font-size:0.9rem;margin-bottom:14px;display:flex;align-items:center;gap:8px;"><i class="fas fa-list" style="color:var(--accent2);"></i> Next Flight Passenger Details</h3>
          <form action="/staff/manager/passengerDetails" method="POST">
            <div class="wm-form-group">
              <label>Route</label>
              <select class="wm-select" name="route_code">
                <option value="">Select route</option>
                <% if (routes) { routes.forEach(function(r) { %>
                  <option value="<%= r.route_id %>"><%= r.route_id %> — <%= r.origin %> → <%= r.destination %></option>
                <% }); } %>
              </select>
            </div>
            <button type="submit" class="wm-btn wm-btn-outline wm-btn-sm" id="passenger-details-btn"><i class="fas fa-users"></i> View Passengers</button>
          </form>
        </div>

        <!-- Past Flights Report -->
        <div class="wm-card">
          <h3 style="font-size:0.9rem;margin-bottom:14px;display:flex;align-items:center;gap:8px;"><i class="fas fa-history" style="color:var(--warning);"></i> Past Flight Reports</h3>
          <form action="/staff/manager/pastFlightReport" method="POST">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div class="wm-form-group">
                <label>Origin</label>
                <select class="wm-select" name="old_origin">
                  <option value="">Select origin</option>
                  <% if (airportCodes) { airportCodes.forEach(function(ap) { %>
                    <option value="<%= ap.airport_code %>"><%= ap.airport_code %></option>
                  <% }); } %>
                </select>
              </div>
              <div class="wm-form-group">
                <label>Destination</label>
                <select class="wm-select" name="old_destination">
                  <option value="">Select destination</option>
                  <% if (airportCodes) { airportCodes.forEach(function(ap) { %>
                    <option value="<%= ap.airport_code %>"><%= ap.airport_code %></option>
                  <% }); } %>
                </select>
              </div>
            </div>
            <button type="submit" class="wm-btn wm-btn-outline wm-btn-sm" id="past-flights-btn"><i class="fas fa-history"></i> View Report</button>
          </form>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
