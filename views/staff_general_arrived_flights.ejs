<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Arrived Flights — Wing Mate Staff</title>
  <link rel="shortcut icon" href="/assets/images/Logo/tab_logo.png" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css">
  <link rel="stylesheet" href="/assets/css/wingmate.css">
</head>
<body>
<div class="wm-staff-layout">
  <aside class="wm-sidebar">
    <div class="wm-sidebar-logo"><span class="logo-icon">✈</span>Wing Mate</div>
    <div class="wm-sidebar-section-title">Operations</div>
    <a href="/staff/general" class="wm-sidebar-link" id="sidebar-home"><i class="fas fa-home"></i> Home</a>
    <a href="/staff/general/arrivedFlights" class="wm-sidebar-link active" id="sidebar-arrived"><i class="fas fa-plane-arrival"></i> Arrived Flights</a>
    <a href="/staff/general/upcomingFlightsMain" class="wm-sidebar-link" id="sidebar-upcoming"><i class="fas fa-plane-departure"></i> Upcoming Flights</a>
    <div class="wm-sidebar-section-title" style="margin-top:12px;">Account</div>
    <a href="/staff/edit_profile" class="wm-sidebar-link" id="sidebar-profile"><i class="fas fa-user-edit"></i> Edit Profile</a>
    <div class="wm-sidebar-bottom">
      <a href="/staff/logout" class="wm-sidebar-link" id="sidebar-logout" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Log Out</a>
    </div>
  </aside>
  <main class="wm-staff-content">
    <div class="wm-staff-topbar">
      <div><h1>Arrived Flights</h1><p style="color:var(--text-muted);font-size:0.88rem;margin-top:4px;">Flights that have landed at your airport</p></div>
      <div class="wm-user-pill">
        <div class="wm-user-avatar"><%= user.staffData.first_name.charAt(0).toUpperCase() %></div>
        <span class="wm-user-name"><%= user.staffData.first_name %></span>
      </div>
    </div>
    <% if (typeof error !== 'undefined' && error) { %><div class="wm-alert wm-alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>
    <% if (typeof success !== 'undefined' && success) { %><div class="wm-alert wm-alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
    <div class="wm-card" style="padding:0;overflow:hidden;">
      <div style="padding:16px 20px;border-bottom:1px solid var(--border);">
        <h3 style="font-size:0.95rem;display:flex;align-items:center;gap:8px;"><i class="fas fa-plane-arrival" style="color:var(--success);"></i> Recently Arrived</h3>
      </div>
      <% if (!arrivedFlights || arrivedFlights.length === 0) { %>
        <div style="text-align:center;padding:60px;color:var(--text-muted);">
          <i class="fas fa-plane-arrival" style="font-size:2rem;margin-bottom:16px;display:block;opacity:0.3;"></i>
          No arrived flights found
        </div>
      <% } else { %>
      <div class="wm-table-wrap" style="border:none;border-radius:0;">
        <table class="wm-table">
          <thead><tr><th>Schedule ID</th><th>Route</th><th>Departure</th><th>Arrival</th><th>Actual Arrival</th><th>Status</th></tr></thead>
          <tbody>
            <% arrivedFlights.forEach(function(f) { %>
            <tr>
              <td><code style="background:var(--bg-elevated);padding:2px 8px;border-radius:4px;font-size:0.8rem;">#<%= f.schedule_id %></code></td>
              <td><%= f.origin %> → <%= f.destination %></td>
              <td style="color:var(--text-muted);font-size:0.82rem;"><%= f.departure_date %></td>
              <td style="color:var(--text-muted);font-size:0.82rem;"><%= f.arrival_date %></td>
              <td style="color:var(--text-muted);font-size:0.82rem;"><%= f.actual_arrival ? new Date(f.actual_arrival).toLocaleString() : '—' %></td>
              <td><span class="wm-badge wm-badge-success"><i class="fas fa-check" style="font-size:0.6em;"></i> Landed</span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
