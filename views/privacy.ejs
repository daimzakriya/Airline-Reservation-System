<%- include('_header', {user}) %>

<!-- Hero Banner Section -->
<section class="wm-hero" style="min-height: 50vh; padding-top: 140px; padding-bottom: 60px;">
  <div class="wm-hero-bg"></div>
  <div class="wm-hero-grid"></div>
  <div class="wm-hero-content" style="max-width: 800px;">
    <div class="wm-hero-pill">
      <span class="wm-hero-pill-dot"></span>
      Legal & Guidelines
    </div>
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 16px;">Terms & Conditions</h1>
    <p style="margin-bottom: 0;">
      Please read our user agreement, cookie policies, and data security guidelines.
    </p>
  </div>
</section>

<!-- Breadcrumb -->
<div style="background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0;">
  <div class="wm-container">
    <div style="display: flex; gap: 8px; font-size: 0.85rem; color: var(--text-secondary);">
      <a href="/" style="color: var(--primary-light); hover:text-decoration: underline;">Home</a>
      <span>/</span>
      <span style="color: var(--text-primary);">Privacy & Terms</span>
    </div>
  </div>
</div>

<!-- Main Terms Section -->
<section class="wm-section-sm">
  <div class="wm-container">
    <div style="max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 24px;">

      <!-- Data Collection -->
      <div class="wm-card" id="datacollect" style="padding: 32px;">
        <h3 style="font-size: 1.25rem; margin-bottom: 16px; font-family: var(--font-display); color: var(--text-primary); border-bottom: 1px solid var(--border); padding-bottom: 10px; display: flex; align-items: center; gap: 10px;">
          <i class="fas fa-database" style="color: var(--primary-light); font-size: 0.95em;"></i> 1. Data Collection
        </h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin-bottom: 12px;">
          The member of the Wingmate Group that initially collects your personal information is responsible for its handling. If a specific type of personal information is not covered in this Privacy Notice, the privacy notice provided at the time of collection will apply.
        </p>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin: 0;">
          Providing your personal information to us is optional. However, if you choose not to provide certain information, we may only be able to offer you limited products and services.
        </p>
      </div>

      <!-- Cookies -->
      <div class="wm-card" id="cookies" style="padding: 32px;">
        <h3 style="font-size: 1.25rem; margin-bottom: 16px; font-family: var(--font-display); color: var(--text-primary); border-bottom: 1px solid var(--border); padding-bottom: 10px; display: flex; align-items: center; gap: 10px;">
          <i class="fas fa-cookie-bite" style="color: var(--accent); font-size: 0.95em;"></i> 2. How We Use Cookies
        </h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin-bottom: 12px;">
          We use cookies, IP addresses, and other tracking technologies on our website, mobile applications, and mobile websites (collectively referred to as "the Platforms") to ensure proper functionality, for analytics, marketing, and to personalize the content you see.
        </p>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin-bottom: 16px;">
          Wingmate Platforms use various types of cookies, including session cookies that are active only during your visit and persistent cookies that remain for a set period. We use both first-party and third-party cookies.
        </p>
        
        <div style="display: flex; flex-direction: column; gap: 12px; margin-left: 12px; border-left: 2px solid var(--primary); padding-left: 16px;">
          <div>
            <strong style="color: var(--text-primary); font-size: 0.92rem; display: block; margin-bottom: 2px;">Essential Cookies</strong>
            <span style="font-size: 0.88rem; color: var(--text-secondary);">Critical for basic operation of our Platforms, including enabling you to log in, progress bookings, or complete reservations.</span>
          </div>
          <div>
            <strong style="color: var(--text-primary); font-size: 0.92rem; display: block; margin-bottom: 2px;">Functional Cookies</strong>
            <span style="font-size: 0.88rem; color: var(--text-secondary);">Enable us to recognize returning visitors, personalize content, and greet you by name dynamically.</span>
          </div>
          <div>
            <strong style="color: var(--text-primary); font-size: 0.92rem; display: block; margin-bottom: 2px;">Marketing Cookies</strong>
            <span style="font-size: 0.88rem; color: var(--text-secondary);">Track website visits, user paths, and travel interest metrics to tailor booking offers and advertisements.</span>
          </div>
        </div>
      </div>

      <!-- Security -->
      <div class="wm-card" id="security" style="padding: 32px;">
        <h3 style="font-size: 1.25rem; margin-bottom: 16px; font-family: var(--font-display); color: var(--text-primary); border-bottom: 1px solid var(--border); padding-bottom: 10px; display: flex; align-items: center; gap: 10px;">
          <i class="fas fa-shield-alt" style="color: var(--success); font-size: 0.95em;"></i> 3. Security
        </h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin: 0;">
          We take reasonable measures to ensure that information you transmit to us remains confidential and protected from unauthorized access. However, we cannot guarantee that unauthorized access will never occur. We will not be held liable for any such unauthorized access unless it is solely caused by our gross negligence, in which case liability is capped at the maximum value of services purchased by you.
        </p>
      </div>

      <!-- Third Party -->
      <div class="wm-card" id="otherwebsites" style="padding: 32px;">
        <h3 style="font-size: 1.25rem; margin-bottom: 16px; font-family: var(--font-display); color: var(--text-primary); border-bottom: 1px solid var(--border); padding-bottom: 10px; display: flex; align-items: center; gap: 10px;">
          <i class="fas fa-external-link-alt" style="color: var(--accent2); font-size: 0.95em;"></i> 4. Third-Party Websites
        </h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin: 0;">
          You may come across external links to third-party websites on our Platforms. Please note that our Privacy Notice does not apply to third-party sites. We are not responsible for the privacy practices of external platforms, and recommend reading their policies before providing personal information.
        </p>
      </div>

      <!-- Intellectual Property -->
      <div class="wm-card" id="propertyrights" style="padding: 32px;">
        <h3 style="font-size: 1.25rem; margin-bottom: 16px; font-family: var(--font-display); color: var(--text-primary); border-bottom: 1px solid var(--border); padding-bottom: 10px; display: flex; align-items: center; gap: 10px;">
          <i class="fas fa-copyright" style="color: var(--warning); font-size: 0.95em;"></i> 5. Intellectual Property Rights
        </h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin: 0;">
          The content and materials featured on our Platforms, including text, graphics, logos, images, digital downloads, database compilations, and software, are protected by intellectual property laws and are owned by Wing Mate, its affiliates, or content suppliers. All rights are reserved.
        </p>
      </div>

      <!-- Website Booking -->
      <div class="wm-card" id="websitebooking" style="padding: 32px;">
        <h3 style="font-size: 1.25rem; margin-bottom: 16px; font-family: var(--font-display); color: var(--text-primary); border-bottom: 1px solid var(--border); padding-bottom: 10px; display: flex; align-items: center; gap: 10px;">
          <i class="fas fa-plane-booking" style="color: var(--primary-light); font-size: 0.95em; content: '✈';">✈</i> 6. Website Booking Terms
        </h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin-bottom: 12px;">
          Tickets can be booked on the website without registering, but we encourage registering to enjoy stored profile benefits. This saves time and streamlines future travel bookings.
        </p>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin: 0;">
          You are responsible for keeping your Login ID, booking reference, and passwords secure. Do not share your login credentials with unauthorized aggregation or mileage tracking services. You are responsible for all activities occurring under your account.
        </p>
      </div>

    </div>
  </div>
</section>

<%- include('_footer', {user}) %>
