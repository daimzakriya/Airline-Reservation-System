<%- include('_header', {user}) %>

<!-- Hero Banner Section -->
<section class="wm-hero" style="min-height: 50vh; padding-top: 140px; padding-bottom: 60px;">
  <div class="wm-hero-bg"></div>
  <div class="wm-hero-grid"></div>
  <div class="wm-hero-content" style="max-width: 800px;">
    <div class="wm-hero-pill" style="background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.25); color: var(--danger);">
      <span class="wm-hero-pill-dot" style="background: var(--danger);"></span>
      Transaction Aborted
    </div>
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 16px; -webkit-text-fill-color: var(--text-primary);">Booking Cancelled</h1>
    <p style="margin-bottom: 0;">
      Your payment was not completed, and the selected seats have been released.
    </p>
  </div>
</section>

<!-- Breadcrumb -->
<div style="background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0;">
  <div class="wm-container">
    <div style="display: flex; gap: 8px; font-size: 0.85rem; color: var(--text-secondary);">
      <a href="/" style="color: var(--primary-light); hover:text-decoration: underline;">Home</a>
      <span>/</span>
      <span style="color: var(--text-primary);">Payment Aborted</span>
    </div>
  </div>
</div>

<section class="wm-section-sm">
  <div class="wm-container">
    <div style="display: flex; justify-content: center;">
      <div style="width: 100%; max-width: 540px; text-align: center;">
        
        <div class="wm-card" style="padding: 40px; border-color: var(--danger); background: rgba(239, 68, 68, 0.03);">
          <div style="width: 56px; height: 56px; background: rgba(239, 68, 68, 0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; color: var(--danger); margin: 0 auto 20px;">
            ✕
          </div>
          <h3 style="font-size: 1.3rem; margin-bottom: 12px; color: var(--text-primary);">Payment Cancelled</h3>
          <p style="color: var(--text-secondary); font-size: 0.92rem; line-height: 1.6; margin-bottom: 28px;">
            The checkout session was cancelled. Any pending seats associated with this reservation have been freed back to the seating map directory.
          </p>

          <div style="display: flex; gap: 14px; justify-content: center;">
            <a href="/" class="wm-btn wm-btn-ghost" style="flex: 1; justify-content: center;">
              <i class="fas fa-home"></i> Home
            </a>
            <a href="/customer/viewFlights" class="wm-btn wm-btn-primary" style="flex: 1; justify-content: center;">
              Try Again <i class="fas fa-redo"></i>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<%- include('_footer', {user}) %>
